# Copy this file to .env and fill in your own values.
# These are consumed by n8n's credential manager / Retell dashboard, not read directly by the workflow.

# Google Calendar OAuth2 (availability checks, create/update/delete events)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# Google Sheets OAuth2 (appointment logging)
GOOGLE_SHEETS_CLIENT_ID=
GOOGLE_SHEETS_CLIENT_SECRET=
GOOGLE_SHEET_ID=

# Retell AI (voice agent orchestration)
RETELL_API_KEY=

# ngrok (local dev tunneling only)
NGROK_AUTHTOKEN=
