      "id": "5162779e-0110-42a2-b875-0447b256bb4d",
      "name": "Get Events in Range",
      "type": "n8n-nodes-base.googleCalendar",
      "typeVersion": 1.3,
      "position": [0, 1184]
    },
    {
      "parameters": {
        "jsCode": "// Get configuration from Workflow Configuration node\nconst config = $('Workflow Configuration1').first().json;\nconst requestedStartTime = new Date(config.requestedStartTime);\nconst dateRangeStart = new Date(config.dateRangeStart);\nconst dateRangeEnd = new Date(config.dateRangeEnd);\nconst slotDuration = 60; // 60 minutes\n\nconst bookedEvents = $input.all().map(item => ({\n  start: new Date(item.json.start.dateTime || item.json.start.date),\n  end: new Date(item.json.end.dateTime || item.json.end.date)\n}));\n\nfunction isSlotAvailable(slotStart, slotEnd) {\n  return !bookedEvents.some(event => {\n    return (slotStart < event.end && slotEnd > event.start);\n  });\n}\n\nconst availableSlots = [];\nlet currentSlot = new Date(dateRangeStart);\n\ncurrentSlot.setMinutes(0, 0, 0);\nif (currentSlot < dateRangeStart) {\n  currentSlot.setHours(currentSlot.getHours() + 1);\n}\n\nwhile (currentSlot < dateRangeEnd) {\n  const slotEnd = new Date(currentSlot.getTime() + slotDuration * 60000);\n  if (slotEnd <= dateRangeEnd && isSlotAvailable(currentSlot, slotEnd)) {\n    availableSlots.push({\n      start: new Date(currentSlot),\n      end: new Date(slotEnd)\n    });\n  }\n  currentSlot.setHours(currentSlot.getHours() + 1);\n}\n\nconst slotsWithDistance = availableSlots.map(slot => ({\n  ...slot,\n  distance: Math.abs(slot.start - requestedStartTime)\n}));\n\nslotsWithDistance.sort((a, b) => a.distance - b.distance);\n\nconst closestSlots = slotsWithDistance.slice(0, 3).map(slot => ({\n  start: slot.start.toISOString(),\n  end: slot.end.toISOString()\n}));\n\nreturn [{\n  json: {\n    requestedTime: requestedStartTime.toISOString(),\n    alternativeSlots: closestSlots,\n    totalAvailableSlots: availableSlots.length\n  }\n}];"
      },
      "id": "f810eaae-aad4-4e88-afe4-c33f05d3c640",
      "name": "Calculate Available Slots",
