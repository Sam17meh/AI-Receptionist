      "id": "8ce03613-f2b2-4212-9297-468c34268bce",
      "name": "Get Events",
      "type": "n8n-nodes-base.googleCalendar",
      "typeVersion": 1.3,
      "position": [0, 240]
    },
    {
      "parameters": {
        "jsCode": "// Get input data from webhook and configuration\nconst webhookData = $('Check & Book').first().json.body;\nconst requestedTime = new Date(webhookData.startTime);\nconst appointmentDuration = $('Workflow Configuration').first().json.appointmentDuration || 60;\nconst workingHoursStart = $('Workflow Configuration').first().json.workingHoursStart || 9;\nconst workingHoursEnd = $('Workflow Configuration').first().json.workingHoursEnd || 17;\nconst searchRangeDays = $('Workflow Configuration').first().json.searchRangeDays || 10;\n\nconst events = $input.all().map(item => item.json);\n\nfunction isSlotAvailable(startTime, durationMinutes, events) {\n  const endTime = new Date(startTime.getTime() + durationMinutes * 60000);\n  for (const event of events) {\n    const eventStart = new Date(event.start.dateTime || event.start.date);\n    const eventEnd = new Date(event.end.dateTime || event.end.date);\n    if (startTime < eventEnd && endTime > eventStart) {\n      return false;\n    }\n  }\n  return true;\n}\n\nfunction isWithinWorkingHours(time, workingHoursStart, workingHoursEnd) {\n  const hour = time.getHours();\n  const minutes = time.getMinutes();\n  const timeInMinutes = hour * 60 + minutes;\n  const startInMinutes = workingHoursStart * 60;\n  const endInMinutes = workingHoursEnd * 60;\n  return timeInMinutes >= startInMinutes && timeInMinutes + appointmentDuration <= endInMinutes;\n}\n\nfunction getTimeDifference(time1, time2) {\n  return Math.abs(time1.getTime() - time2.getTime()) / 60000;\n}\n\nconst availableSlots = [];\nconst startDate = new Date(requestedTime);\nstartDate.setHours(0, 0, 0, 0);\n\nfor (let day = 0; day < searchRangeDays; day++) {\n  const currentDay = new Date(startDate);\n  currentDay.setDate(startDate.getDate() + day);\n\n  const dayOfWeek = currentDay.getDay();\n  if (dayOfWeek === 0 || dayOfWeek === 6) continue;\n\n  currentDay.setHours(workingHoursStart, 0, 0, 0);\n  const dayEnd = new Date(currentDay);\n  dayEnd.setHours(workingHoursEnd, 0, 0, 0);\n\n  for (let time = new Date(currentDay); time < dayEnd; time.setMinutes(time.getMinutes() + 30)) {\n    const slotTime = new Date(time);\n    if (isWithinWorkingHours(slotTime, workingHoursStart, workingHoursEnd) &&\n        isSlotAvailable(slotTime, appointmentDuration, events)) {\n      const endTime = new Date(slotTime.getTime() + appointmentDuration * 60000);\n      const timeDiff = getTimeDifference(slotTime, requestedTime);\n      const isSameDay = slotTime.toDateString() === requestedTime.toDateString();\n\n      availableSlots.push({\n        startTime: slotTime.toISOString(),\n        endTime: endTime.toISOString(),\n        formatted: slotTime.toLocaleString('en-US', {\n          weekday: 'long',\n          year: 'numeric',\n          month: 'long',\n          day: 'numeric',\n          hour: 'numeric',\n          minute: '2-digit',\n          hour12: true\n        }),\n        timeDifference: timeDiff,\n        isSameDay: isSameDay,\n        date: slotTime.toISOString().split('T')[0]\n      });\n    }\n  }\n}\n\navailableSlots.sort((a, b) => {\n  if (a.isSameDay && !b.isSameDay) return -1;\n  if (!a.isSameDay && b.isSameDay) return 1;\n  return a.timeDifference - b.timeDifference;\n});\n\nconst top3Slots = availableSlots.slice(0, 3);\n\nconst suggestedTimes = top3Slots.map(slot => ({\n  startTime: slot.startTime,\n  endTime: slot.endTime,\n  formatted: slot.formatted\n}));\n\nreturn {\n  json: {\n    suggestedTimes: suggestedTimes,\n    requestedTime: requestedTime.toISOString(),\n    totalSlotsFound: availableSlots.length,\n    searchedDays: searchRangeDays,\n    appointmentDuration: appointmentDuration\n  }\n};"
      },
